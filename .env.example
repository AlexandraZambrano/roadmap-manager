# ── SQL Database ─────────────────────────────────────────────────────────────
# SQL_DIALECT options: mysql | mariadb | mssql | postgres | sqlite
SQL_DIALECT=
SQL_HOST=
SQL_PORT=
SQL_DATABASE=
SQL_USER=
SQL_PASSWORD=
# Set SQL_SSL=true if your remote DB requires SSL (most cloud providers do)
SQL_SSL=false

# ── Email ─────────────────────────────────────────────────────────────────────
EMAIL_USER=
EMAIL_PASSWORD=

# ── Environment ───────────────────────────────────────────────────────────────
# "development" → EXTERNAL_AUTH_URL_DEV | "production" → EXTERNAL_AUTH_URL_PROD
NODE_ENV=production

# ── External Auth API (Symfony) ───────────────────────────────────────────────
EXTERNAL_AUTH_URL_DEV=http://localhost:8000
EXTERNAL_AUTH_URL_PROD=

# ── RS256 Public Key (auth server) ────────────────────────────────────────────
# Paste the full PEM content in a single line, replacing real newlines with \n
# Example:
#   EXTERNAL_JWT_PUBLIC_KEY=-----BEGIN PUBLIC KEY-----\nMIIBIjANBg...\n-----END PUBLIC KEY-----
# If this variable is not set, the server will fall back to backend/keys/public.pem
EXTERNAL_JWT_PUBLIC_KEY=