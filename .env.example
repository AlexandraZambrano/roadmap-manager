# ── Server ──────────────────────────────────────────────────────────────────
PORT=3000
NODE_ENV=development

# ── Auth externa (RS256) ─────────────────────────────────────────────────────
# El token que emite users.coderf5.es se verifica con la llave pública RSA
# que está en backend/keys/public.pem — no hace falta ningún secreto aquí.
#
# URL base de la API de auth:
#   NODE_ENV=development → EXTERNAL_AUTH_URL_DEV  (ej. tu Symfony local)
#   NODE_ENV=production  → EXTERNAL_AUTH_URL_PROD (https://users.coderf5.es)
EXTERNAL_AUTH_URL_DEV=http://localhost:8000
EXTERNAL_AUTH_URL_PROD=https://users.coderf5.es

# ── JWT interno (HS256) ──────────────────────────────────────────────────────
# Solo se usa como fallback para cuentas locales (admin panel, estudiantes).
# Los profesores que se loguean con la API externa NO usan esto.
JWT_SECRET=pon_aqui_un_secreto_largo_y_aleatorio

# ── MongoDB ──────────────────────────────────────────────────────────────────
# Dentro de docker-compose el servicio app apunta al servicio "mongo".
# Para correr el servidor directamente en el host (sin docker): mongodb://localhost:27017/bootcamp-manager
MONGO_URI=mongodb://mongo:27017/bootcamp-manager

# ── Migración (solo para migrate-to-local.js) ────────────────────────────────
# MONGO_URI_LOCAL: el mongo del docker expuesto al host (puerto 27017)
# MONGO_URI_CLOUD: tu connection string de Atlas actual
MONGO_URI_LOCAL=mongodb://localhost:27017/bootcamp-manager
MONGO_URI_CLOUD=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/bootcamp-manager?retryWrites=true&w=majority

